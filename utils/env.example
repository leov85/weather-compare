# env.example — Configuration template for the Weather Comparison Bot

# ── Telegram ──────────────────────────────────────────────
TELEGRAM_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ── Visual Crossing (free tier: 1000 req/day) ──────────────
# Get your key at: https://www.visualcrossing.com/weather-api
VISUALCROSSING_API_KEY=your_api_key_here

# ── OpenWeatherMap (optional, not used by default) ─────────
OWM_API_KEY=your_owm_key_here

# ── SSL Verification ───────────────────────────────────────
VERIFY_SSL=True

# ── Proxy (optional) ───────────────────────────────────────
# Uncomment and fill in if you need to route traffic through a proxy
# HTTP_PROXY=http://username:password@proxyserver:port
# HTTPS_PROXY=http://username:password@proxyserver:port
